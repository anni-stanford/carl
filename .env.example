# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=          # required for real (non-dry-run) episodes
OPENAI_API_KEY=             # optional; enables family rotation in the LLM judge

# CARL behavior
CARL_LOG_LEVEL=INFO

# Replay buffer (v1 uses SQLite; v2 will read this)
DATABASE_URL=postgresql://carl:carl@localhost:5432/carl
