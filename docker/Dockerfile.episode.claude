# Episode sandbox for the Claude Code adapter.
# Used by carl/env/docker_sandbox.py to run a single episode in isolation.
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work

COPY pyproject.toml ./
RUN pip install --upgrade pip && pip install -e ".[dev]" || true

# Claude Agent SDK is added during episode bootstrap (so the sandbox image stays
# small and we can pin per-episode).
CMD ["bash"]
